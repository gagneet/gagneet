    <!-- What I Do -->
    <section id="about" class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 section-title">What I Do</h2>
                <p class="mt-6 text-xl text-gray-600 max-w-3xl mx-auto">
                    I operate at the intersection of product, engineering, and delivery — turning ambiguous problems
                    into working software that creates real business value.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-gradient-to-br from-violet-50 to-indigo-50 rounded-2xl p-8 border border-violet-100 card-hover">
                    <div class="w-12 h-12 bg-violet-600 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">Technical Product Management</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Defining product vision, prioritising roadmaps, and aligning engineering capacity with business outcomes.
                        Deep enough technically to challenge architecture decisions, pragmatic enough to ship.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="px-2 py-1 text-xs font-medium tag-purple rounded-full">Roadmapping</span>
                        <span class="px-2 py-1 text-xs font-medium tag-purple rounded-full">Stakeholder Mgmt</span>
                        <span class="px-2 py-1 text-xs font-medium tag-purple rounded-full">Agile / Scrum</span>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-8 border border-blue-100 card-hover">
                    <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">Principal / Staff Engineering</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Designing distributed systems and cloud-native architectures that scale. Leading technical direction,
                        setting engineering standards, and mentoring senior engineers across cross-functional teams.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="px-2 py-1 text-xs font-medium tag-blue rounded-full">System Design</span>
                        <span class="px-2 py-1 text-xs font-medium tag-blue rounded-full">Cloud Architecture</span>
                        <span class="px-2 py-1 text-xs font-medium tag-blue rounded-full">Tech Leadership</span>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl p-8 border border-emerald-100 card-hover">
                    <div class="w-12 h-12 bg-emerald-600 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">Full-Stack Development</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Hands-on development from database schema to pixel-perfect UI. Building production applications
                        with Next.js, React, Node.js, PostgreSQL, and modern DevOps pipelines.
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <span class="px-2 py-1 text-xs font-medium tag-green rounded-full">Next.js / React</span>
                        <span class="px-2 py-1 text-xs font-medium tag-green rounded-full">Node.js</span>
                        <span class="px-2 py-1 text-xs font-medium tag-green rounded-full">PostgreSQL</span>
                    </div>
                </div>
            </div>

            <!-- Principles -->
            <div class="mt-16 grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-8">Guiding Principles</h3>
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center mt-0.5">
                                <div class="w-2 h-2 bg-violet-600 rounded-full"></div>
                            </div>
                            <div>
                                <h4 class="font-semibold text-gray-900">"Ship value, not features"</h4>
                                <p class="text-gray-600 mt-1">Every engineering decision should trace back to a measurable user or business outcome.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center mt-0.5">
                                <div class="w-2 h-2 bg-violet-600 rounded-full"></div>
                            </div>
                            <div>
                                <h4 class="font-semibold text-gray-900">"Automation over repetition"</h4>
                                <p class="text-gray-600 mt-1">If a process can be automated, it should be. Manual work is technical debt waiting to happen.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="flex-shrink-0 w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center mt-0.5">
                                <div class="w-2 h-2 bg-violet-600 rounded-full"></div>
                            </div>
                            <div>
                                <h4 class="font-semibold text-gray-900">"Security by design, not by chance"</h4>
                                <p class="text-gray-600 mt-1">Security must be baked into architecture from day one — not retrofitted after an incident.</p>
                            </div>
                        </div>
                    </div>
                </div>
